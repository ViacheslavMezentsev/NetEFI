		<region region-id="344" left="6" top="51" width="378.75" height="181.5" align-x="144" align-y="66" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
			<math optimize="false" disable-calc="false">
				<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
					<ml:function>
						<ml:id xml:space="preserve">implicitplot2d</ml:id>
						<ml:boundVars>
							<ml:id xml:space="preserve">f</ml:id>
							<ml:id xml:space="preserve">coords</ml:id>
							<ml:id xml:space="preserve">grids</ml:id>
						</ml:boundVars>
					</ml:function>
					<ml:program>
						<ml:localDefine>
							<ml:matrix rows="1" cols="2">
								<ml:id xml:space="preserve">nx</ml:id>
								<ml:id xml:space="preserve">ny</ml:id>
							</ml:matrix>
							<ml:apply>
								<ml:transpose/>
								<ml:id xml:space="preserve">grids</ml:id>
							</ml:apply>
						</ml:localDefine>
						<ml:localDefine>
							<ml:matrix rows="2" cols="2">
								<ml:id xml:space="preserve">xmax</ml:id>
								<ml:id xml:space="preserve">xmin</ml:id>
								<ml:id xml:space="preserve">ymax</ml:id>
								<ml:id xml:space="preserve">ymin</ml:id>
							</ml:matrix>
							<ml:id xml:space="preserve">coords</ml:id>
						</ml:localDefine>
						<ml:localDefine>
							<ml:matrix rows="1" cols="2">
								<ml:id xml:space="preserve">Δx</ml:id>
								<ml:id xml:space="preserve">Δy</ml:id>
							</ml:matrix>
							<ml:matrix rows="1" cols="2">
								<ml:apply>
									<ml:div/>
									<ml:apply>
										<ml:minus/>
										<ml:id xml:space="preserve">xmax</ml:id>
										<ml:id xml:space="preserve">xmin</ml:id>
									</ml:apply>
									<ml:id xml:space="preserve">nx</ml:id>
								</ml:apply>
								<ml:apply>
									<ml:div/>
									<ml:apply>
										<ml:minus/>
										<ml:id xml:space="preserve">ymax</ml:id>
										<ml:id xml:space="preserve">ymin</ml:id>
									</ml:apply>
									<ml:id xml:space="preserve">ny</ml:id>
								</ml:apply>
							</ml:matrix>
						</ml:localDefine>
						<ml:localDefine>
							<ml:apply>
								<ml:indexer/>
								<ml:id xml:space="preserve">zvalues</ml:id>
								<ml:sequence>
									<ml:id xml:space="preserve">nx</ml:id>
									<ml:id xml:space="preserve">ny</ml:id>
								</ml:sequence>
							</ml:apply>
							<ml:real>0</ml:real>
						</ml:localDefine>
						<ml:for>
							<ml:id xml:space="preserve">n</ml:id>
							<ml:range>
								<ml:real>0</ml:real>
								<ml:id xml:space="preserve">nx</ml:id>
							</ml:range>
							<ml:for>
								<ml:id xml:space="preserve">m</ml:id>
								<ml:range>
									<ml:real>0</ml:real>
									<ml:id xml:space="preserve">ny</ml:id>
								</ml:range>
								<ml:localDefine>
									<ml:apply>
										<ml:indexer/>
										<ml:id xml:space="preserve">zvalues</ml:id>
										<ml:sequence>
											<ml:id xml:space="preserve">n</ml:id>
											<ml:id xml:space="preserve">m</ml:id>
										</ml:sequence>
									</ml:apply>
									<ml:apply>
										<ml:id xml:space="preserve">f</ml:id>
										<ml:sequence>
											<ml:apply>
												<ml:plus/>
												<ml:id xml:space="preserve">xmin</ml:id>
												<ml:apply>
													<ml:mult/>
													<ml:id xml:space="preserve">n</ml:id>
													<ml:id xml:space="preserve">Δx</ml:id>
												</ml:apply>
											</ml:apply>
											<ml:apply>
												<ml:plus/>
												<ml:id xml:space="preserve">ymin</ml:id>
												<ml:apply>
													<ml:mult/>
													<ml:id xml:space="preserve">m</ml:id>
													<ml:id xml:space="preserve">Δy</ml:id>
												</ml:apply>
											</ml:apply>
										</ml:sequence>
									</ml:apply>
								</ml:localDefine>
							</ml:for>
						</ml:for>
						<ml:return>
							<ml:apply>
								<ml:id xml:space="preserve">csimplot2d</ml:id>
								<ml:sequence>
									<ml:id xml:space="preserve">Δx</ml:id>
									<ml:id xml:space="preserve">Δy</ml:id>
									<ml:id xml:space="preserve">xmin</ml:id>
									<ml:id xml:space="preserve">ymin</ml:id>
									<ml:id xml:space="preserve">zvalues</ml:id>
								</ml:sequence>
							</ml:apply>
						</ml:return>
					</ml:program>
